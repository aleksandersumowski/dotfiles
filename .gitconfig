[user]
        name = Aleksander Sumowski
        email = 


[alias]
	co = checkout
	br = branch
	st = status
	df = diff
        praise = blame
    up = log origin/master..master
    reb = pull --rebase

[apply]
        whitespace = strip

[pager]
        color = true

[status]
        color = auto
[core]
	editor = /usr/bin/vim
[push]
	default = simple
